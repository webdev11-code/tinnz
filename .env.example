# Discord Webhook URL untuk menerima notifikasi pengajuan sponsorship
# Cara mendapatkan:
# 1. Buka Discord Server -> Server Settings -> Integrations -> Webhooks
# 2. Buat Webhook baru, salin URL-nya
# 3. Paste di bawah (ganti URL dengan webhook kamu)
#
# Untuk development (lokal):
#   Copy file ini jadi .env dan isi URL webhook
#
# Untuk production (Vercel):
#   Set环境变量 VITE_DISCORD_SPONSOR_WEBHOOK di dashboard Vercel:
#   Settings -> Environment Variables -> tambahin VITE_DISCORD_SPONSOR_WEBHOOK
#
VITE_DISCORD_SPONSOR_WEBHOOK=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
